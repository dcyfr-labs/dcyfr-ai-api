{
  "name": "@dcyfr/ai-api",
  "version": "2.0.0",
  "private": true,
  "description": "Production-ready REST API starter template with Express 5, Drizzle ORM, JWT, and OpenAPI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "native:sqlite:ensure": "node scripts/ensure-native-sqlite.mjs",
    "predev": "npm run native:sqlite:ensure",
    "dev": "tsx watch src/index.ts",
    "prestart": "npm run native:sqlite:ensure",
    "start": "node dist/index.js",
    "prebuild": "npm run native:sqlite:ensure",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "npm run native:sqlite:ensure",
    "test": "vitest",
    "pretest:run": "npm run native:sqlite:ensure",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "pretest:coverage": "npm run native:sqlite:ensure",
    "test:coverage": "vitest run --coverage",
    "examples:compile": "tsc --noEmit --module nodenext --moduleResolution nodenext --target es2022 --strict --esModuleInterop true --skipLibCheck true examples/custom-route/posts-router.ts examples/middleware/custom-middleware.ts",
    "examples:check": "npm run examples:compile",
    "examples:test": "npm run examples:check",
    "db:generate": "drizzle-kit generate",
    "predb:migrate": "npm run native:sqlite:ensure",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "linear:webhook:setup": "node scripts/setup-linear-github-webhook.mjs",
    "predb:seed": "npm run native:sqlite:ensure",
    "db:seed": "tsx src/db/seed.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "dcyfr",
    "api",
    "express",
    "rest",
    "typescript",
    "drizzle",
    "template"
  ],
  "author": "DCYFR Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-api"
  },
  "bugs": {
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-api/issues"
  },
  "homepage": "https://github.com/dcyfr-labs/dcyfr-ai-api#readme",
  "overrides": {
    "esbuild": "0.25.0"
  }
}
