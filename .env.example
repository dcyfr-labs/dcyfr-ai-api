# Environment
NODE_ENV=development
PORT=3001

# Database (SQLite for development)
DATABASE_URL=./data/dev.db

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# API Keys (comma-separated)
API_KEYS=dev-api-key-1,dev-api-key-2

# CORS Configuration
# Comma-separated list of allowed origins (no wildcards)
# Development: http://localhost:3000,http://localhost:3001
# Production: https://www.dcyfr.ai,https://dcyfr-labs.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=debug

# Linear ↔ GitHub sync (Phase 2)
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret
# Use 1Password CLI reference — resolved via: op run --env-file=.env -- <command>
LINEAR_API_KEY=op://CI-CD/Linear/api_key
DRY_RUN=true

# Pilot webhook setup helper (`npm run linear:webhook:setup`)
GITHUB_TOKEN=replace-with-github-token
GITHUB_OWNER=dcyfr-labs
GITHUB_REPO=dcyfr-ai
WEBHOOK_URL=https://api.dcyfr.ai/api/linear-sync/github-webhook
WEBHOOK_EVENTS=pull_request

# Review-service repo allowlist (closes CodeQL js/request-forgery).
# Webhooks from repos NOT in this list are rejected with 403.
# Empty in production = deny all (fail-closed). Empty in dev = allow all.
# Format: comma-separated entries — exact ('dcyfr-labs/dcyfr-labs') or
# owner-wildcard ('dcyfr-labs/*').
REVIEW_ALLOWED_REPOS=dcyfr-labs/*

# Optional rate-limit overrides (defaults: 60/min auth+writes, 300/min reads)
# RATE_LIMIT_AUTH_MAX=60
# RATE_LIMIT_READ_MAX=300
# RATE_LIMIT_WRITE_MAX=60
